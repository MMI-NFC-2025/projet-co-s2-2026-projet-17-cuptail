---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Mes favoris">
<section class="min-h-[calc(100vh-64px)] bg-white">
  <div class="bg-mint px-4 py-8">
    <div class="mx-auto max-w-6xl">
      <div class="mb-8">
        <h1 class="page-title">Mes favoris</h1>

        <p class="page-subtitle mt-3 text-brand-warmGray">
          Retrouvez toutes vos boissons préférées
        </p>
      </div>

      <div
        id="favoris-grid"
        class="grid grid-cols-2 justify-items-center gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
      ></div>
    </div>
  </div>

<div class="bg-white px-4 py-10">
  <div class="mx-auto max-w-6xl">
    <div class="rounded-[28px] bg-seaBreeze p-6 shadow-card md:mx-auto md:max-w-xl">
      <div class="flex gap-4">
        <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-white shadow-soft">
          <img src="/icons/info.svg" class="h-5 w-5" alt="" />
        </div>

        <div>
          <h2 class="text-[18px] font-bold text-black">Astuce</h2>

          <p class="mt-3 text-[14px] leading-6 text-brand-warmGray">
            Appuyez sur le cœur à côté d’une boisson pour l’ajouter à vos favoris.
            Vous pourrez ainsi les retrouver facilement ici !
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
  </section>
</Layout>

<script>
  import { pb } from '../../backend/backend.js';

  const API_BASE = 'https://api.ruslanabudniak.fr';
  const grid = document.querySelector('#favoris-grid') as HTMLDivElement | null;

  const categoryColors: Record<string, string> = {
    Thé: 'bg-brand-green',
    Thés: 'bg-brand-green',
    Infusions: 'bg-[#E8B84D]',
    Cocktails: 'bg-brand-red',
    'Cocktails sans alcool': 'bg-brand-red',
    Smoothies: 'bg-[#8B7CF6]',
    Café: 'bg-[#9B7E72]',
    Protéines: 'bg-[#FF7A4F]',
    'Boissons protéinées': 'bg-[#FF7A4F]',
    Végétales: 'bg-[#A7C77A]',
    'Boissons végétales': 'bg-[#A7C77A]',
    Fermentées: 'bg-[#6ED9D0]',
    'Boissons fermentées': 'bg-[#6ED9D0]',
    'Boissons légumes': 'bg-[#5FCF4B]',
    Légumes: 'bg-[#5FCF4B]',
  };

  function getImageUrl(boisson: any) {
    const fileName = Array.isArray(boisson.photo_boisson)
      ? boisson.photo_boisson[0]
      : boisson.photo_boisson;

    return fileName
      ? `${API_BASE}/api/files/${boisson.collectionId}/${boisson.id}/${fileName}`
      : '/images/placeholder-drink.png';
  }

  function getCategoryName(boisson: any) {
    const expandedCategories = boisson.expand?.categories || boisson.expand?.categorie;

    const firstCategory = Array.isArray(expandedCategories)
      ? expandedCategories[0]
      : expandedCategories;

    return (
      firstCategory?.nom_categorie ||
      firstCategory?.categories_boissons ||
      'Boisson'
    );
  }

  function renderCard(boisson: any) {
    const imageUrl = getImageUrl(boisson);
    const category = getCategoryName(boisson);
    const categoryColor = categoryColors[category] || 'bg-brand-green';
    const description = boisson.description_courte || '';

    return `
      <article class="flex h-[276px] w-[156px] shrink-0 flex-col overflow-hidden rounded-2xl bg-card shadow-panel transition duration-200 hover:-translate-y-1 hover:shadow-card md:h-[318px] md:w-[178px]">
        <div class="relative h-[146px] shrink-0 md:h-[168px]">
          <span class="absolute left-[14px] top-[8px] z-10 rounded-full px-3 py-1 text-center text-[9px] font-bold leading-[13.5px] text-white md:text-[10px] ${categoryColor}">
            ${category}
          </span>

          <button
            class="js-favorite absolute right-[14px] top-[8px] z-10 grid h-[21px] w-[21px] place-items-center rounded-full bg-white shadow-soft transition hover:scale-110 md:h-6 md:w-6"
            type="button"
            aria-label="Retirer des favoris"
            data-boisson-id="${boisson.id}"
            data-favorite-active="true"
          >
            <img class="h-[9px] w-[10px] md:h-[10px] md:w-[11px]" src="/icons/heart-full.svg" alt="" />
          </button>

          <img
            class="absolute left-1/2 top-[14px] h-[132px] w-[146px] -translate-x-1/2 object-contain md:h-[152px] md:w-[168px]"
            src="${imageUrl}"
            alt="${boisson.nom_boisson}"
            loading="lazy"
          />
        </div>

        <div class="flex flex-1 flex-col bg-white px-[15px] pb-4 pt-[13px] md:px-[18px] md:pb-5 md:pt-4">
          <h3 class="line-clamp-2 min-h-[32px] text-[13px] font-bold leading-[16px] text-black md:min-h-[40px] md:text-[15px] md:leading-5">
            ${boisson.nom_boisson}
          </h3>

          <p class="mt-1.5 line-clamp-2 text-[11px] font-normal leading-[16px] text-brand-warmGray md:text-[13px] md:leading-[18px]">
            ${description}
          </p>

          <a
            class="mt-auto flex items-center justify-between pt-3 text-[12px] font-bold text-brand-turquoise no-underline md:text-[14px]"
            href="/boissons/${boisson.slug}"
          >
            <span>Voir la recette</span>

            <span class="grid h-6 w-6 place-items-center rounded-full bg-white shadow-soft md:h-7 md:w-7">
              <img class="h-[13px] w-[9px]" src="/icons/arrow-right.svg" alt="" />
            </span>
          </a>
        </div>
      </article>
    `;
  }

  async function loadFavoris() {
    if (!grid) return;

    if (!pb.authStore.isValid || !pb.authStore.model) {
      grid.innerHTML = `
        <div class="col-span-full rounded-[28px] bg-white p-8 text-center shadow-card">
          <p class="text-lg font-bold text-black">Connecte-toi pour voir tes favoris</p>
          <a href="/login" class="mt-5 inline-flex rounded-full bg-brand-turquoise px-6 py-3 text-sm font-bold text-black shadow-button">
            Se connecter
          </a>
        </div>
      `;
      return;
    }

    const favoris = await pb.collection('favoris').getFullList({
      filter: `user = "${pb.authStore.model.id}"`,
      sort: '-created',
      expand: 'boisson.categories,boisson.categorie',
    });

    const boissons = favoris
      .map((favori: any) => favori.expand?.boisson)
      .filter(Boolean);

    if (!boissons.length) {
      grid.innerHTML = `
        <div class="col-span-full rounded-[28px] bg-white p-8 text-center shadow-card">
          <p class="text-lg font-bold text-black">Aucune boisson favorite</p>
          <p class="mt-2 text-sm text-neutral-500">Ajoute des boissons en cliquant sur le cœur.</p>
          <a href="/boissons" class="mt-5 inline-flex rounded-full bg-brand-turquoise px-6 py-3 text-sm font-bold text-black shadow-button">
            Découvrir les boissons
          </a>
        </div>
      `;
      return;
    }

    grid.innerHTML = boissons.map(renderCard).join('');
    window.dispatchEvent(new CustomEvent('favorites:refresh'));
  }

  document.addEventListener('DOMContentLoaded', loadFavoris);
  window.addEventListener('favorites:changed', loadFavoris);
</script>