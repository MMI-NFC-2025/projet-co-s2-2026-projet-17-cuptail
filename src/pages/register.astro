---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inscription">
  <section class="min-h-[calc(100vh-64px)] bg-white px-4 py-10">
    <div class="mx-auto max-w-[420px] rounded-[28px] bg-mint p-6 shadow-card">
      <h1 class="page-title">Créer un compte</h1>

      <form id="register-form" class="mt-8 flex flex-col gap-4">
        <input class="rounded-full bg-white px-5 py-3 shadow-soft outline-none" name="name" placeholder="Nom" required />
        <input class="rounded-full bg-white px-5 py-3 shadow-soft outline-none" name="email" type="email" placeholder="Email" required />
        <input
  class="rounded-full bg-white px-5 py-3 shadow-soft outline-none"
  name="password"
  type="password"
  placeholder="Mot de passe"
  minlength="8"
  required
/>
<p class="mt-[-8px] px-5 text-xs text-neutral-400">
  Minimum 8 caractères.
</p>

        <label class="rounded-[24px] bg-white p-4 shadow-soft">
          <span class="text-sm font-bold">Photo de profil</span>
          <input class="mt-3 w-full text-sm" name="avatar" type="file" accept="image/*" />
          <p class="mt-2 text-xs text-neutral-400">
  Image JPG/PNG, maximum 5 Mo.
</p>
        </label>

        <button class="mt-4 rounded-full bg-brand-turquoise px-6 py-3 font-bold text-black shadow-button" type="submit">
          S’inscrire
        </button>

        <p id="register-message" class="text-sm font-bold"></p>
      </form>

      <a href="/login" class="mt-6 block text-center text-sm font-bold text-brand-turquoise">
        Déjà un compte ? Se connecter
      </a>
    </div>
  </section>
</Layout>

<script>
  import { registerUser } from '../backend/backend.js';

  const form = document.querySelector('#register-form') as HTMLFormElement | null;
  const message = document.querySelector('#register-message') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);

    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const avatarFile = formData.get('avatar');

   if (avatarFile instanceof File && avatarFile.size > 5 * 1024 * 1024) {
  if (message) {
    message.textContent = 'Image trop lourde. Choisis une image de moins de 5 Mo.';
    message.className = 'text-sm font-bold text-brand-red';
  }
  return;
}

    try {
      await registerUser({
        name,
        email,
        password,
        avatar: avatarFile instanceof File && avatarFile.size > 0 ? avatarFile : null,
      });

      if (message) {
        message.textContent = 'Compte créé. Tu peux maintenant te connecter.';
        message.className = 'text-sm font-bold text-brand-turquoise';
      }

      setTimeout(() => {
        window.location.href = '/login';
      }, 1200);
    } catch (error) {
      console.error('REGISTER ERROR:', error);

      const pbError = error as any;

      let errorText = 'Erreur pendant l’inscription.';

      if (pbError?.response?.data) {
        errorText = Object.values(pbError.response.data)
          .map((item: any) => item.message)
          .filter(Boolean)
          .join(' ');
      } else if (pbError?.data) {
        errorText = Object.values(pbError.data)
          .map((item: any) => item.message)
          .filter(Boolean)
          .join(' ');
      } else if (pbError?.message) {
        errorText = pbError.message;
      }

      if (message) {
        message.textContent = errorText || 'Erreur pendant l’inscription.';
        message.className = 'text-sm font-bold text-brand-red';
      }
    }
  });
</script>