---
import { getFileUrl } from '../backend/backend.js';

const { weather, context, label, message, boisson } = Astro.props;

const imageUrl = boisson?.photo_boisson
  ? getFileUrl(boisson, Array.isArray(boisson.photo_boisson) ? boisson.photo_boisson[0] : boisson.photo_boisson)
  : '/images/placeholder-drink.png';

const categoryName = boisson?.expand?.categorie?.nom_categorie || 'Notre recommandation';
---

<section class="mx-auto w-full max-w-[360px] rounded-[32px] bg-gradient-to-b from-cyan-100 to-[#F7FFF4] px-6 pb-5 pt-8 shadow-lg">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-bold text-black">📍 Montbéliard</p>
      <p class="mt-4 text-[42px] font-black leading-none text-black">
        {Math.round(weather.temperature_2m)}°C
      </p>
      <p class="mt-2 text-xl font-bold text-black">{label}</p>
      <p class="mt-3 text-base font-bold text-neutral-400">{message}</p>
    </div>

    <div class="text-5xl">
      {context === 'pluie' ? '🌧️' : context === 'froid' ? '❄️' : context === 'nuageux' ? '☁️' : '☀️'}
    </div>
  </div>

  <div class="relative mt-8 min-h-[250px]">
    <img
      class="absolute right-0 top-0 h-[210px] w-[145px] object-contain"
      src={imageUrl}
      alt={boisson.nom_boisson}
    />

    <div class="absolute bottom-0 left-0 right-0 rounded-3xl bg-white p-5 shadow-lg">
      <p class="text-sm font-bold text-black">☀️ Notre recommandation</p>

      <h2 class="mt-4 text-2xl font-black text-black">
        {boisson.nom_boisson}
      </h2>

      <p class="mt-3 max-w-[200px] text-base font-bold text-neutral-400">
        {boisson.description_courte}
      </p>

      <div class="mt-4 flex items-center justify-between">
        <a
          href={`/boissons/${boisson.slug}`}
          class="inline-flex items-center gap-3 rounded-full bg-[var(--turquoise-brand)] px-8 py-3 text-sm font-black text-black shadow-md"
        >
          Voir la recette
          <span>›</span>
        </a>

        <div class="rounded-2xl bg-white p-3 text-xs font-bold shadow-sm">
          <p>🕘 {boisson.temps_preparation} min</p>
          <p>📊 {boisson.difficulte}</p>
          <p>{boisson.is_vegan ? '♻️ Vegan' : '🥛 Non vegan'}</p>
        </div>
      </div>
    </div>
  </div>
</section>