---
import AnimatedBlobs from './AnimatedBlobs.astro';
---

<section id="quiz-section" class="scroll-mt-20 bg-white px-4 py-10 md:py-16">
  <div class="relative mx-auto max-w-5xl overflow-hidden rounded-[42px] bg-quiz px-5 py-10 md:px-12 md:py-16">
    <AnimatedBlobs opacity="opacity-35" />

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <div id="quiz-intro">
  <h2 class="mx-auto max-w-[270px] text-[24px] font-bold leading-[1.18] text-black sm:max-w-[520px] sm:text-[32px] md:text-[40px]">
    Envie d’une boisson qui te correspond vraiment ?
  </h2>

  <p class="mx-auto mt-8 max-w-[260px] text-[17px] font-bold leading-[1.7] text-neutral-400 sm:max-w-[560px] sm:text-[24px] md:text-[30px]">
    Réponds à 3 questions et découvre une sélection personnalisée.
  </p>

  <button
    id="quiz-start"
    class="mt-8 inline-flex w-full max-w-[260px] items-center justify-center gap-6 rounded-[26px] border-2 border-[#72F6F3] bg-button px-8 py-3 text-[22px] font-bold text-black shadow-[var(--shadow-quiz-button)] transition hover:scale-105 active:scale-95 md:mt-10 md:max-w-none md:px-16 md:py-4 md:text-[28px]"
  >
    Commencer
    <span class="h-0 w-0 border-y-[10px] border-l-[12px] border-y-transparent border-l-white md:border-y-[12px] md:border-l-[14px]"></span>
  </button>
</div>

      <div id="quiz-card" class="hidden">
        <h2 class="mb-8 text-[28px] font-bold leading-tight text-[#4b0f3f] md:text-[34px]">
          Envie de quelque<br class="md:hidden" /> chose de précis ?
        </h2>

        <div class="mx-auto rounded-[42px] border border-white/50 bg-[#E9FFFD]/40 p-6 shadow-[var(--shadow-quiz-card)] md:max-w-[620px] md:p-10">
          <h3 id="quiz-question" class="text-[18px] font-bold text-[#4b0f3f] md:text-[24px]">
            Question
          </h3>

          <div id="quiz-options" class="mt-7 grid overflow-hidden rounded-[20px] bg-white/70 md:mx-auto md:max-w-[480px]"></div>

          <button
  id="quiz-next"
  class="mt-7 inline-flex items-center gap-6 rounded-[26px] border-2 border-[#72F6F3] bg-button px-10 py-3 text-[16px] font-bold text-white shadow-[var(--shadow-quiz-button)] transition hover:scale-105 active:scale-95 md:px-14"
>
  Suivant
  <span class="h-0 w-0 border-y-[7px] border-l-[9px] border-y-transparent border-l-white"></span>
</button>
        </div>
      </div>

      <div id="quiz-results" class="hidden">
        <h2 class="text-[28px] font-bold text-black md:text-[36px]">
          Ta sélection personnalisée
        </h2>

        <p class="mt-3 text-[16px] font-bold text-neutral-400 md:text-[18px]">
          Voici les boissons qui correspondent à tes réponses.
        </p>

        <div id="quiz-results-list" class="mt-8 flex gap-4 overflow-x-auto pb-4 md:grid md:grid-cols-3 md:overflow-visible"></div>

        <button
          id="quiz-restart"
          class="mt-6 rounded-full bg-brand-turquoise px-8 py-3 text-sm font-bold text-black shadow-button"
        >
          Refaire le quiz
        </button>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const API_BASE = 'https://api.ruslanabudniak.fr';

  const intro = document.querySelector('#quiz-intro');
  const card = document.querySelector('#quiz-card');
  const results = document.querySelector('#quiz-results');

  const startButton = document.querySelector('#quiz-start');
  const nextButton = document.querySelector('#quiz-next');
  const restartButton = document.querySelector('#quiz-restart');

  const questionEl = document.querySelector('#quiz-question');
  const optionsEl = document.querySelector('#quiz-options');
  const resultsList = document.querySelector('#quiz-results-list');

  let currentStep = 0;
  let answers = {};

  const questions = [
    {
      key: 'temperature_service',
      title: 'Tu veux une boisson...',
      columns: 'grid-cols-2',
      options: [
        { label: 'Froid', value: 'froid', image: '/icons/weather/ice.svg' },
        { label: 'Chaud', value: 'chaud', image: '/icons/weather/hot.svg' },
      ],
    },
    {
      key: 'profil_gout',
      title: 'Quel goût préfères-tu ?',
      columns: 'grid-cols-3',
      options: [
        { label: 'Fruité', value: 'fruite', image: '/icons/quiz/fruit.png' },
        { label: 'Légume', value: 'legume', image: '/icons/quiz/vegetable.png' },
        { label: 'Baies', value: 'baies', image: '/icons/quiz/berries.png' },
      ],
    },
    {
      key: 'taux_sucre',
      title: 'Quel niveau de douceur ?',
      columns: 'grid-cols-2',
      options: [
        { label: 'Sucré', value: 'moyen', image: '/icons/quiz/sweet.png' },
        { label: 'En mesure', value: 'faible', image: '/icons/quiz/medium-sugar.png' },
      ],
    },
  ];

  function showStep() {
    const question = questions[currentStep];

    questionEl.textContent = question.title;
    optionsEl.className = `mt-7 grid ${question.columns} overflow-hidden rounded-[20px] bg-white/70 md:mx-auto md:max-w-[480px]`;

    optionsEl.innerHTML = question.options.map((option) => {
      const isSelected = answers[question.key] === option.value;

      return `
        <button
          type="button"
          data-value="${option.value}"
          class="quiz-option flex flex-col items-center justify-center px-3 py-4 transition ${isSelected ? 'bg-brand-greenSoft' : 'bg-white/40 hover:bg-white/80'}"
        >
          <img src="${option.image}" class="h-14 w-14 object-contain md:h-20 md:w-20" alt="" />
          <span class="mt-1 text-[14px] font-bold text-black md:text-[17px]">${option.label}</span>
        </button>
      `;
    }).join('');

    optionsEl.querySelectorAll('.quiz-option').forEach((button) => {
      button.addEventListener('click', () => {
        answers[question.key] = button.dataset.value;
        showStep();
      });
    });
  }

  function getBoissonImageUrl(boisson) {
    const fileName = Array.isArray(boisson.photo_boisson) ? boisson.photo_boisson[0] : boisson.photo_boisson;

    return fileName
      ? `${API_BASE}/api/files/${boisson.collectionId}/${boisson.id}/${fileName}`
      : '/images/placeholder-drink.png';
  }

  async function getQuizResults() {
    const filters = [
      'is_active = true',
      `temperature_service = "${answers.temperature_service}"`,
      `profil_gout = "${answers.profil_gout}"`,
      `taux_sucre = "${answers.taux_sucre}"`,
    ];

    const url = new URL(`${API_BASE}/api/collections/boissons/records`);
    url.searchParams.set('filter', filters.join(' && '));
    url.searchParams.set('expand', 'categorie');
    url.searchParams.set('perPage', '20');
    url.searchParams.set('sort', '-is_recommended,-is_new,nom_boisson');

    const response = await fetch(url);
    const data = await response.json();

    return data.items || [];
  }

  async function getFallbackResults() {
    const filters = [
      'is_active = true',
      `temperature_service = "${answers.temperature_service}"`,
      `profil_gout = "${answers.profil_gout}"`,
    ];

    const url = new URL(`${API_BASE}/api/collections/boissons/records`);
    url.searchParams.set('filter', filters.join(' && '));
    url.searchParams.set('expand', 'categorie');
    url.searchParams.set('perPage', '20');

    const response = await fetch(url);
    const data = await response.json();

    return data.items || [];
  }

  function renderResults(boissons) {
    if (!boissons.length) {
      resultsList.innerHTML = `
        <div class="rounded-[28px] bg-white p-6 text-center shadow-card md:col-span-3">
          <p class="text-lg font-bold text-black">Aucun résultat exact.</p>
          <p class="mt-2 text-sm font-bold text-neutral-400">Essaie une autre combinaison.</p>
        </div>
      `;
      return;
    }

    resultsList.innerHTML = boissons.slice(0, 6).map((boisson) => {
      const imageUrl = getBoissonImageUrl(boisson);
      const category = boisson.expand?.categorie?.nom_categorie || 'Boisson';

      return `
        <article class="min-w-[220px] rounded-[24px] bg-card p-4 shadow-card md:min-w-0">
          <div class="flex items-start justify-between">
            <span class="rounded-full bg-brand-green px-4 py-1 text-[11px] font-bold text-white">${category}</span>
          </div>

          <img src="${imageUrl}" alt="${boisson.nom_boisson}" class="mx-auto mt-3 h-[120px] w-[120px] object-contain" />

          <h3 class="mt-4 text-[18px] font-bold text-black">${boisson.nom_boisson}</h3>
          <p class="mt-2 line-clamp-2 text-[13px] font-bold text-neutral-400">${boisson.description_courte || ''}</p>

          <a href="/boissons/${boisson.slug}" class="mt-4 inline-flex rounded-full bg-brand-turquoise px-5 py-2 text-sm font-bold text-black shadow-button">
            Voir la recette
          </a>
        </article>
      `;
    }).join('');
  }

  async function showResults() {
    card.classList.add('hidden');
    results.classList.remove('hidden');

    resultsList.innerHTML = '<p class="text-sm font-bold text-neutral-500">Chargement...</p>';

    let boissons = await getQuizResults();

    if (!boissons.length) {
      boissons = await getFallbackResults();
    }

    renderResults(boissons);
  }

  startButton.addEventListener('click', () => {
    intro.classList.add('hidden');
    card.classList.remove('hidden');
    currentStep = 0;
    answers = {};
    showStep();
  });

  nextButton.addEventListener('click', () => {
    const currentQuestion = questions[currentStep];

    if (!answers[currentQuestion.key]) {
      return;
    }

    if (currentStep < questions.length - 1) {
      currentStep += 1;
      showStep();
    } else {
      showResults();
    }
  });

  restartButton.addEventListener('click', () => {
    results.classList.add('hidden');
    intro.classList.remove('hidden');
    currentStep = 0;
    answers = {};
  });
</script>