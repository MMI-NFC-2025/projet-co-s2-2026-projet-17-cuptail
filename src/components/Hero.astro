---
import AnimatedBlobs from './AnimatedBlobs.astro';
---

<section class="relative flex min-h-[calc(100vh-64px)] w-full items-center justify-center overflow-hidden bg-spring px-6 pb-16 pt-16">
  <AnimatedBlobs opacity="opacity-80" />

  <div class="pointer-events-none absolute inset-0 z-[1] bg-white/10"></div>

  <div class="relative z-10 flex max-w-[520px] flex-col items-center text-center">
    <h1 class="text-[48px] font-bold leading-[118.5%] md:text-[72px]">
      <span class="text-[#00E9DD]">Ciel</span><span class="text-brand-red">ixir</span>
    </h1>

    <p class="mt-4 max-w-[320px] text-[16px] font-bold leading-[118.5%] text-black md:max-w-[440px] md:text-[18px]">
      Trouve une boisson parfaite selon la météo et ton envie
    </p>

    <a
      href="#weather-section"
      class="mt-12 rounded-full bg-brand-turquoise px-7 py-3 text-[15px] font-semibold text-black shadow-button transition hover:scale-105 active:scale-95"
    >
      Trouver ma boisson
    </a>
  </div>
</section>